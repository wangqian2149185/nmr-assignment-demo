# Copy this file to .env and add your own Anthropic API key.
# Do not commit .env to GitHub.
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Optional. Pick any Anthropic model available to your account.
ANTHROPIC_MODEL=claude-opus-4-7

# Optional local server port.
PORT=8765

# Optional. Only this many low-confidence/blank peaks are sent to the second LLM refinement step.
# Set to 0 to disable refinement and only use the compact residue map plus programmatic fill.
AMBIGUOUS_REFINE_LIMIT=40

# Optional. Fragment validation is batched to avoid max-token failures.
FRAGMENT_VALIDATION_BATCH_SIZE=4
FRAGMENT_VALIDATION_MAX_BATCHES=8
FRAGMENT_VALIDATION_MAX_TOKENS=4000
